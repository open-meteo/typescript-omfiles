{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "lib": ["es2024", "dom"],
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    // Don't emit files - Rollup will handle that
    "noEmit": true,
  },
  "include": ["src/**/*"],
}
